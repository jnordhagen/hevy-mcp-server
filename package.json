{
	"name": "hevy-mcp-server",
	"version": "3.1.0",
	"description": "A Model Context Protocol (MCP) server for the Hevy fitness tracking API, deployed on Cloudflare Workers with Hono framework",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"hevy",
		"fitness",
		"cloudflare-workers",
		"ai",
		"claude"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/tomtorggler/hevy-mcp-server.git"
	},
	"bugs": {
		"url": "https://github.com/tomtorggler/hevy-mcp-server/issues"
	},
	"homepage": "https://github.com/tomtorggler/hevy-mcp-server#readme",
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev --env dev --port 8787",
		"format": "biome format --write",
		"lint:fix": "biome lint --fix",
		"start": "wrangler dev --env dev --port 8787",
		"cf-typegen": "wrangler types",
		"type-check": "tsc --noEmit",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"test:run": "vitest run",
		"mcp:local": "tsx src/local.ts"
	},
	"dependencies": {
		"@cloudflare/workers-oauth-provider": "^0.0.11",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"agents": "^0.7.9",
		"hono": "^4.12.25",
		"octokit": "^5.0.4",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@cloudflare/workers-types": "^4.20260616.1",
		"@types/node": "^24.7.2",
		"@vitest/ui": "^4.1.9",
		"tsx": "^4.22.4",
		"typescript": "5.9.3",
		"vitest": "^4.1.9",
		"wrangler": "^4.100.0"
	},
	"overrides": {
		"esbuild": "^0.28.1",
		"ws": "^8.21.0"
	}
}
